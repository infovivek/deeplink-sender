# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
REFRESH_SECRET=your_refresh_secret_key_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Redis Configuration (for BullMQ)
REDIS_URL=redis://localhost:6379

# Application Configuration
BASE_URL=http://localhost:5000
NODE_ENV=development
PORT=5000

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Deeplink Security
DEEPLINK_SIGN_SECRET=your_deeplink_signing_secret

# Optional: MongoDB (if switching from PostgreSQL)
# MONGO_URL=mongodb://localhost:27017/whatsapp_sender

# Rate Limiting (optional)
MAX_TABS_PER_CLICK=5
MAX_MESSAGES_PER_MINUTE=10

# Security (optional)
CORS_ORIGIN=http://localhost:5000
COOKIE_SECRET=your_cookie_secret
